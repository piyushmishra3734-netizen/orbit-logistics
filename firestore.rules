rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /* ── OWNER CHECK ── */
    function isOwner() {
      return request.auth != null &&
             request.auth.token.email == 'piyushmishra3734@gmail.com';
    }

    /* ── USER CHECK ── */
    function isUser(uid) {
      return request.auth != null && request.auth.uid == uid;
    }

    /* ── QUOTES ──────────────────────────────────────── */
    match /quotes/{quoteId} {
      /* Customer can create their own quotes */
      allow create: if request.auth != null
                    && request.resource.data.customerUid == request.auth.uid;

      /* Customer can read their own quotes; owner can read all */
      allow read: if isOwner()
                  || (request.auth != null
                      && resource.data.customerUid == request.auth.uid);

      /* Customer may update ONLY the status field, and ONLY to the two
         legitimate customer transitions (accept / reject a revision). They
         cannot self-approve or set arbitrary statuses. Owner is unrestricted. */
      allow update: if isOwner()
                    || (request.auth != null
                        && resource.data.customerUid == request.auth.uid
                        && request.resource.data.diff(resource.data).affectedKeys()
                           .hasOnly(['status','updatedAt','respondedAt'])
                        && request.resource.data.status in ['customer_accepted','customer_rejected']
                        && resource.data.status == 'revised_by_owner');
    }

    /* ── ORDERS ──────────────────────────────────────── */
    match /orders/{orderId} {
      /* Only owner can create orders */
      allow create: if isOwner();

      /* Customer reads their own orders; owner reads all */
      allow read: if isOwner()
                  || (request.auth != null
                      && resource.data.customerUid == request.auth.uid);

      /* Only owner can update order status */
      allow update: if isOwner();
    }

    /* ── NOTIFICATIONS (customer reads own; owner writes) ── */
    match /notifications/{notifId} {
      allow read: if request.auth != null
                  && resource.data.customerUid == request.auth.uid;
      allow create: if request.auth != null;   /* customer can create quote_submitted notif */
      allow update: if request.auth != null
                    && resource.data.customerUid == request.auth.uid
                    && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['read']);
      allow delete: if false;
    }

    /* ── OWNER NOTIFICATIONS (customer writes; owner reads) ── */
    match /ownerNotifications/{notifId} {
      allow create: if request.auth != null;
      allow read:   if isOwner();
      allow update: if isOwner();
    }

    /* ── ACTIVITY LOG ─────────────────────────────────── */
    match /activityLog/{uid}/entries/{entryId} {
      allow read:   if isUser(uid) || isOwner();
      allow create: if request.auth != null;   /* both customer and owner can write activity */
      allow update, delete: if false;
    }

    /* ── AUDIT LOGS — append-only business record ─────── */
    match /auditLogs/{logId} {
      /* Only the owner can view the audit trail */
      allow read:   if isOwner();
      /* Any authenticated action (customer or owner) can write a log entry */
      allow create: if request.auth != null;
      /* Immutable — no edits or deletions, ever */
      allow update, delete: if false;
    }

    /* ── ORDER TIMELINES — per-order audit history, append-only ── */
    match /orderTimelines/{orderId}/events/{eventId} {
      /* Customer reads their own order's timeline; owner reads all.
         Timeline entries mirror auditLogs, so for simplicity any
         authenticated user may read (no sensitive fields beyond the
         order they already have access to). Owner-only is enforced in UI. */
      allow read:   if request.auth != null;
      allow create: if request.auth != null;
      allow update, delete: if false;
    }

    /* ── QUOTE TIMELINES — per-quote audit history, append-only ── */
    match /quoteTimelines/{quoteId}/events/{eventId} {
      allow read:   if request.auth != null;
      allow create: if request.auth != null;
      allow update, delete: if false;
    }

    /* ── INVOICES ──────────────────────────────────────── */
    match /invoices/{invoiceId} {
      /* Invoices are created by the system at order creation (owner action)
         and via the owner fallback generator. */
      allow create: if isOwner();
      /* Customer reads their own invoices; owner reads all */
      allow read: if isOwner()
                  || (request.auth != null
                      && resource.data.customerUid == request.auth.uid);
      /* Only the owner can update an invoice (payment status, amounts) */
      allow update: if isOwner();
      /* Permanent business record — never deleted */
      allow delete: if false;
    }

    /* ── LORRY RECEIPTS ────────────────────────────────── */
    match /lorryReceipts/{lrId} {
      /* Created by the system at order approval (owner action). */
      allow create: if isOwner();
      /* Customer reads their own LRs; owner reads all */
      allow read: if isOwner()
                  || (request.auth != null
                      && resource.data.customerUid == request.auth.uid);
      /* Only the owner can edit transport details / payment status */
      allow update: if isOwner();
      /* Permanent business record — never deleted */
      allow delete: if false;
    }

    /* ── COMPANIES (commercial directory, shared) ───────── */
    match /companies/{companyId} {
      /* Any authenticated user may read (powers the quote autofill)
         and create/merge (saving a new company for future reuse). */
      allow read:   if request.auth != null;
      allow create: if request.auth != null;
      allow update: if request.auth != null;
      allow delete: if isOwner();
    }

    /* ── INVOICE CONFIG (signature, bank details, brand) ── */
    match /invoiceConfig/{docId} {
      /* Any authenticated user may read it (needed to render the PDF);
         only the owner may change the signature / bank details. */
      allow read:   if request.auth != null;
      allow write:  if isOwner();
    }

    /* ── COUNTERS (sequential IDs) ───────────────────── */
    match /counters/{counter} {
      allow read, write: if request.auth != null;
    }

    /* ── PROFILES ─────────────────────────────────────── */
    match /profiles/{uid} {
      allow read, write: if isUser(uid) || isOwner();
    }

    /* ── SAVED ROUTES ─────────────────────────────────── */
    match /routes/{uid}/saved/{routeId} {
      allow read, write: if isUser(uid) || isOwner();
    }

    /* ══ ACCOUNTING — OWNER ONLY ══════════════════════════
       Customers are viewers of invoices/LRs only; they have NO access to any
       accounting collection. Posted journal entries are IMMUTABLE: they may be
       created and read, and only their status/void-link fields may be patched
       (to mark a void). They can never be deleted — corrections are new entries. */
    match /accounts/{code} {
      allow read, write: if isOwner();
    }
    match /parties/{partyId} {
      allow read, write: if isOwner();
    }
    match /accountingSettings/{doc} {
      allow read, write: if isOwner();
    }
    match /journalEntries/{entryId} {
      allow read:   if isOwner();
      allow create: if isOwner()
                    && request.resource.data.totalDebit == request.resource.data.totalCredit;
      /* Only allow updates that mark an entry void / add a posting key — never
         changes to amounts or lines of a posted entry. */
      allow update: if isOwner()
                    && request.resource.data.totalDebit == resource.data.totalDebit
                    && request.resource.data.totalCredit == resource.data.totalCredit
                    && request.resource.data.lines == resource.data.lines;
      allow delete: if false;
    }
    match /vouchers/{voucherId} {
      allow read, write: if isOwner();
    }
  }
}
