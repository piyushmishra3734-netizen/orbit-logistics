# ============================================================================
#  Orbit Logistics — .gitignore  (repo root)
#
#  Repo layout:
#    EGC-Logistics-System/   the web app + Cloud Functions
#    qa/                     offline test suites
# ============================================================================

# --- Dependencies (regenerated via npm install) ---
node_modules/
**/node_modules/

# --- Cloud Functions vendor copies (regenerated by sync-vendor.js on deploy) ---
EGC-Logistics-System/functions/vendor/

# --- Local / secret config (copy the .example templates and fill in) ---
EGC-Logistics-System/firebase-config.js
EGC-Logistics-System/.firebaserc
**/.runtimeconfig.json
**/.env
**/.env.*

# --- Firebase tooling ---
.firebase/
*-debug.log*
*.log

# --- Build / release artifacts ---
release/
dist/
build/
*.zip

# --- OS / editor noise ---
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp
*~

# --- Test / coverage output ---
coverage/
.nyc_output/
playwright-report/
test-results/
