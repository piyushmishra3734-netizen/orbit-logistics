{
  "functions": {
    "source": "functions",
    "runtime": "nodejs20",
    "predeploy": [
      "node \"$RESOURCE_DIR/sync-vendor.js\""
    ]
  },
  "firestore": {
    "rules": "firestore.rules",
    "indexes": "firestore.indexes.json"
  },
  "hosting": {
    "public": ".",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**",
      "functions/**",
      "qa/**",
      "test/**",
      "*-preview.png",
      "README.md"
    ],
    "rewrites": []
  }
}
